---
// 03 — The wrong side of the line (dark). Ported from "Water on Paper.dc.html"
// (scratchpad copy water.html lines 214–294); the {{ countryList }} widget
// reconstructs countriesEl() (logic class) as static markup over `countries`,
// and the sticky detail panel is server-rendered for the default selection
// (selCountry:"IN"), then updated client-side by the script below.
// {{ bottled }} and {{ polluters }} are static maps over the data tables.
import {
  countries,
  defaultCountry,
  countryByKey,
  countryTitle,
  stressLabel,
  stressColor,
  rank,
  bottled,
  polluters,
} from '../../data/water';

const sel = countryByKey(defaultCountry);
---

<section id="ch03" data-screen-label="03 The wrong side" data-wopdark style="padding:clamp(80px,12vh,150px) var(--gut);background:var(--water-ink);color:oklch(0.92 0.015 240)">
  <div style="max-width:var(--maxw);margin:0 auto">
    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);max-width:var(--col);margin-bottom:clamp(40px,6vh,68px)">
      <span style="font-family:var(--mono);font-size:.72rem;letter-spacing:.2em;color:var(--water-light);display:inline-flex;gap:.7em;align-items:center"><span style="width:26px;height:1px;background:currentColor;opacity:.6"></span>03 — The wrong side of the line</span>
      <h2 style="font-family:var(--serif);font-weight:400;letter-spacing:-.015em;line-height:1.0;font-size:clamp(2.6rem,6vw,5rem);margin:.2em 0 .4em;max-width:20ch;color:var(--paper)">The line runs through every continent.</h2>
      <p style="font-size:clamp(1.2rem,1.9vw,1.5rem);line-height:1.45;color:oklch(0.86 0.02 240)">Not one region — everywhere the paper outran the plumbing. This is who lives on the wrong side of it.</p>
    </div>

    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);margin-bottom:22px">
      <h3 style="font-family:var(--serif);font-weight:400;font-size:clamp(1.8rem,3.2vw,2.6rem);line-height:1.05;margin:0 0 .3em;color:var(--paper);max-width:20ch">Ten countries on the wrong side of the line.</h3>
      <p style="font-size:1rem;color:oklch(0.82 0.02 240);max-width:62ch;margin:0">A deliberate spread — Middle-Eastern aquifers run dry, Asian giants outgrow their rivers, and across sub-Saharan Africa the barrier is distance, not scarcity. India sits in company, not isolation. Choose a country.<button class="cite" data-src="Country water-stress ratings: WRI Aqueduct Water Risk Atlas. Individual cases — Cape Town 2018 'Day Zero', Chennai 2019, the over-allocated Colorado River, Mexico City subsidence — from national agencies and contemporaneous reporting." data-url="https://www.wri.org/aqueduct" aria-label="Source" style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border:1px solid var(--water-light);border-radius:50%;font-family:var(--mono);font-size:8px;color:var(--water-light);vertical-align:super;margin-left:3px;line-height:1">i</button></p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(24px,3.5vw,52px);align-items:start;margin-bottom:clamp(64px,9vh,110px)">
      <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1)">
        <div id="wop_countries" role="group" aria-label="Ten water-stressed countries" style="display:flex;flex-direction:column;border-bottom:1px solid oklch(1 0 0 /0.12)">
          {countries.map((c, i) => (
            <button
              type="button"
              class:list={['wop-tile', c.key === defaultCountry && 'is-sel']}
              data-key={c.key}
              aria-pressed={c.key === defaultCountry ? 'true' : 'false'}
              aria-label={`${c.name} — ${c.region} — ${stressLabel(c.stress)}`}
              style="display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;width:100%;text-align:left;font:inherit;cursor:pointer;padding:15px 14px;transition:background .2s"
            >
              <span aria-hidden="true" style="font-family:var(--mono);font-size:0.74rem;color:oklch(0.66 0.02 240)">{rank(i)}</span>
              <span style="min-width:0">
                <span style={`display:block;font-family:var(--serif);font-size:1.3rem;line-height:1.05;color:${c.deepdive ? 'var(--water-light)' : 'var(--paper)'}`}>{countryTitle(c)}</span>
                <span style="display:block;font-family:var(--mono);font-size:0.66rem;letter-spacing:0.08em;text-transform:uppercase;color:oklch(0.68 0.02 240);margin-top:2px">{c.region}</span>
              </span>
              <span style="display:flex;align-items:center;gap:10px">
                <span style="font-family:var(--mono);font-size:0.8rem;color:oklch(0.84 0.02 240)">{c.stat}</span>
                <span aria-hidden="true" style={`width:10px;height:10px;border-radius:50%;background:${stressColor(c.stress)}`}></span>
              </span>
            </button>
          ))}
        </div>
      </div>
      <div data-reveal aria-live="polite" style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1) .08s,transform .9s cubic-bezier(.2,.6,.2,1) .08s;position:sticky;top:88px;border:1px solid oklch(1 0 0 /0.12);border-radius:10px;background:oklch(1 0 0 /0.03);padding:clamp(24px,2.8vw,36px)">
        <h3 id="wop_country_name" style="font-family:var(--serif);font-weight:400;font-size:clamp(1.9rem,3.4vw,2.6rem);line-height:1;margin:0 0 2px;color:var(--paper)">{sel.name}</h3>
        <p id="wop_country_region" style="font-family:var(--mono);font-size:.74rem;color:var(--water-light);letter-spacing:.04em;margin:0 0 20px">{sel.region}</p>
        <div style="display:flex;gap:16px;align-items:baseline;margin-bottom:22px;padding-bottom:22px;border-bottom:1px solid oklch(1 0 0 /0.12)">
          <span id="wop_country_stat" style={`font-family:var(--serif);font-size:clamp(2.4rem,5vw,3.4rem);line-height:.85;color:${stressColor(sel.stress)}`}>{sel.stat}</span>
          <span id="wop_country_statlbl" style="font-size:.96rem;line-height:1.4;color:oklch(0.86 0.02 240)">{sel.statLbl}</span>
        </div>
        <div style="margin-bottom:18px"><div style="font-family:var(--mono);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:oklch(0.7 0.02 240);margin-bottom:6px">The challenge</div><div id="wop_country_challenge" style="font-size:.98rem;line-height:1.5;color:oklch(0.9 0.015 240)">{sel.challenge}</div></div>
        <div style="margin-bottom:18px"><div style="font-family:var(--mono);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:oklch(0.7 0.02 240);margin-bottom:6px">Where the water comes from</div><div id="wop_country_source" style="font-size:.98rem;line-height:1.5;color:oklch(0.9 0.015 240)">{sel.source}</div></div>
        <div><div style="font-family:var(--mono);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:oklch(0.7 0.02 240);margin-bottom:8px">Groups working on it</div>
          <div id="wop_country_orgs">
            {sel.orgs.map((org) => (
              <div style="padding:9px 0;border-top:1px solid oklch(1 0 0 /0.1)"><div style="font-size:.92rem;color:var(--paper)">{org.name}</div><div style="font-family:var(--mono);font-size:.72rem;color:oklch(0.72 0.02 240)">{org.what}</div></div>
            ))}
          </div>
        </div>
        <a id="wop_country_deep" href="#ch04" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;font-family:var(--sans);font-weight:600;font-size:.92rem;color:var(--water-ink);background:var(--water-light);padding:11px 18px;border-radius:5px">Open the India deep dive ↓</a>
      </div>
    </div>

    <!-- Bottled water: when did water become a business -->
    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);max-width:var(--col);margin-bottom:clamp(36px,5vh,60px)">
      <span style="font-family:var(--mono);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--water-light)">An aside · the business of thirst</span>
      <h3 style="font-family:var(--serif);font-weight:400;font-size:clamp(1.9rem,3.6vw,2.9rem);line-height:1.05;margin:.3em 0 .4em;color:var(--paper);max-width:22ch">When did water stop being free and start being a brand?</h3>
      <p style="font-size:1.05rem;line-height:1.55;color:oklch(0.86 0.02 240)">The same century that began writing water down as a right also learned to sell it back by the bottle. It took about two hundred years to turn a spring into a $300-billion market.</p>
    </div>

    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);margin-bottom:clamp(30px,4vh,48px)">
      <div style="display:flex;flex-direction:column">
        {bottled.map((ev) => (
          <div style="display:grid;grid-template-columns:clamp(64px,10vw,120px) 1fr;gap:clamp(16px,3vw,36px);padding:20px 0;border-top:1px solid oklch(1 0 0 /0.12);align-items:baseline">
            <div style="font-family:var(--serif);font-size:clamp(1.5rem,3vw,2.4rem);line-height:1;color:var(--water-light)">{ev.yr}</div>
            <div><div style="font-family:var(--sans);font-weight:600;font-size:1.05rem;color:var(--paper);margin-bottom:4px">{ev.t}</div><div style="font-size:.96rem;line-height:1.5;color:oklch(0.84 0.02 240);max-width:64ch">{ev.d}</div></div>
          </div>
        ))}
      </div>
    </div>

    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);border-left:3px solid var(--clay);background:oklch(1 0 0 /0.03);padding:clamp(20px,2.6vw,30px) clamp(22px,3vw,34px);border-radius:0 8px 8px 0;max-width:80ch;margin-bottom:clamp(64px,9vh,110px)">
      <div style="font-family:var(--mono);font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:oklch(0.82 0.06 60);margin-bottom:10px">The ethics of it</div>
      <p style="font-size:1.05rem;line-height:1.55;margin:0;color:oklch(0.9 0.015 240)">A litre of premium bottled water can cost a thousand times what the tap charges — and much of it is drawn from springs and aquifers, sometimes in water-stressed ground, wrapped in plastic and shipped across the world. The purified brands are quieter still: <em style="font-family:var(--serif);font-style:italic">Dasani and Aquafina are essentially filtered municipal tap water</em>, sold back to the public that already owns it. Convenience is real. So is the question of who gets to fence off a human right.<button class="cite" data-src="Bottled vs tap: premium bottled water can cost hundreds to a thousand times municipal tap water per litre; Coca-Cola’s Dasani and PepsiCo’s Aquafina are purified public/municipal water supplies (company disclosures; contemporaneous reporting)." aria-label="Source" style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border:1px solid var(--water-light);border-radius:50%;font-family:var(--mono);font-size:8px;color:var(--water-light);vertical-align:super;margin-left:4px;line-height:1">i</button></p>
    </div>

    <!-- Who pollutes water most -->
    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);max-width:var(--col);margin-bottom:clamp(30px,4vh,48px)">
      <span style="font-family:var(--mono);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--water-light)">Follow the poison upstream</span>
      <h3 style="font-family:var(--serif);font-weight:400;font-size:clamp(1.9rem,3.6vw,2.9rem);line-height:1.05;margin:.3em 0 .4em;color:var(--paper);max-width:20ch">Who pollutes the water — and who is responsible?</h3>
      <p style="font-size:1.05rem;line-height:1.55;color:oklch(0.86 0.02 240)">Scarcity is only half the story. Plenty of water is poisoned before it ever reaches a tap. Three sources do most of the damage — and none of them is the person drinking it.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:clamp(16px,2.4vw,28px);margin-bottom:clamp(56px,8vh,90px)">
      {polluters.map((p) => (
        <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);border:1px solid oklch(1 0 0 /0.12);border-radius:10px;padding:clamp(22px,2.6vw,32px);background:oklch(1 0 0 /0.03)">
          <div style={`font-family:var(--serif);font-size:clamp(2.6rem,5vw,3.6rem);line-height:.85;color:${p.color}`}>{p.big}</div>
          <div style="font-family:var(--sans);font-weight:600;font-size:1.12rem;color:var(--paper);margin:.5em 0 .2em">{p.name}</div>
          <div style="font-family:var(--mono);font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;color:var(--water-light);margin-bottom:10px">{p.who}</div>
          <p style="font-size:.94rem;line-height:1.5;color:oklch(0.84 0.02 240);margin:0">{p.detail}<button class="cite" data-src={p.src} aria-label="Source" style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border:1px solid var(--water-light);border-radius:50%;font-family:var(--mono);font-size:8px;color:var(--water-light);vertical-align:super;margin-left:4px;line-height:1">i</button></p>
        </div>
      ))}
    </div>

    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);max-width:var(--col)">
      <p style="font-size:1.15rem;line-height:1.55;color:oklch(0.9 0.015 240)">The global numbers are the wide shot. To see how the gap actually behaves — how a country can pour billions into pipes and still bury people who drank from them — we go to the place with the most people, the least margin, and the most water written down. <em style="font-family:var(--serif);font-style:italic;color:var(--water-light)">India.</em></p>
    </div>
  </div>
</section>

<style>
  /* Selection-dependent row properties (prototype countriesEl() inline styles,
     moved to a class so the script can toggle them). border-top lives here
     too: it shares the `border` shorthand with the selection-driven
     border-left, and an inline `border:0` would override the class rule. */
  .wop-tile {
    background: transparent;
    border: 0;
    border-top: 1px solid oklch(1 0 0 /0.12);
    border-left: 2px solid transparent;
  }
  .wop-tile.is-sel {
    background: oklch(1 0 0 /0.06);
    border-left-color: var(--water-light);
  }
  /* Keyboard ring (dark section). */
  .wop-tile:focus-visible {
    outline: 2px solid var(--water-light);
    outline-offset: 2px;
  }
</style>

<script>
  import { countryByKey, stressColor } from '../../data/water';

  const list = document.getElementById('wop_countries');
  if (list) {
    const el = (id: string) => document.getElementById(id);
    const name = el('wop_country_name');
    const region = el('wop_country_region');
    const stat = el('wop_country_stat');
    const statLbl = el('wop_country_statlbl');
    const challenge = el('wop_country_challenge');
    const source = el('wop_country_source');
    const orgs = el('wop_country_orgs');
    const deep = el('wop_country_deep');

    const select = (key: string): void => {
      const c = countryByKey(key);
      list.querySelectorAll<HTMLButtonElement>('.wop-tile').forEach((b) => {
        const isSel = b.dataset.key === c.key;
        b.classList.toggle('is-sel', isSel);
        b.setAttribute('aria-pressed', String(isSel));
      });
      if (name) name.textContent = c.name;
      if (region) region.textContent = c.region;
      if (stat) {
        stat.textContent = c.stat;
        stat.style.color = stressColor(c.stress);
      }
      if (statLbl) statLbl.textContent = c.statLbl;
      if (challenge) challenge.textContent = c.challenge;
      if (source) source.textContent = c.source;
      if (orgs) {
        orgs.textContent = '';
        for (const org of c.orgs) {
          const row = document.createElement('div');
          row.style.cssText = 'padding:9px 0;border-top:1px solid oklch(1 0 0 /0.1)';
          const orgName = document.createElement('div');
          orgName.style.cssText = 'font-size:.92rem;color:var(--paper)';
          orgName.textContent = org.name;
          const orgWhat = document.createElement('div');
          orgWhat.style.cssText = 'font-family:var(--mono);font-size:.72rem;color:oklch(0.72 0.02 240)';
          orgWhat.textContent = org.what;
          row.append(orgName, orgWhat);
          orgs.append(row);
        }
      }
      if (deep) deep.style.display = c.deepdive ? 'inline-flex' : 'none';
    };

    list.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.wop-tile[data-key]');
      if (btn && btn.dataset.key) select(btn.dataset.key);
    });
  }
</script>
