---
// 08 · The levers — solutions, Learn/Give resources, promise-vs-proof close.
// Ported from "Water on Paper.dc.html" lines 505–552; markup byte-faithful
// apart from the conventions' mechanical transforms (sc-for → map, citation
// spans → <button class="cite">, straight apostrophes → typographic in prose).
// Fully static: reveals and cite popovers are handled by the shared essay engine.
import { solutions, awareLearn, awareGive } from '../../data/water';
---
<section id="ch08" data-screen-label="08 The levers" style="padding:clamp(80px,12vh,150px) var(--gut)">
  <div style="max-width:var(--maxw);margin:0 auto">
    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);max-width:var(--col);margin-bottom:clamp(44px,6vh,72px)">
      <span style="font-family:var(--mono);font-size:.72rem;letter-spacing:.2em;color:var(--ink-faint);display:inline-flex;gap:.7em;align-items:center"><span style="width:26px;height:1px;background:currentColor;opacity:.6"></span>08 — Closing the gap</span>
      <h2 style="font-family:var(--serif);font-weight:400;letter-spacing:-.015em;line-height:1.0;font-size:clamp(2.6rem,6vw,5rem);margin:.2em 0 .4em;max-width:16ch">Make the paper truer. Then make it real.</h2>
      <p style="font-size:clamp(1.25rem,2vw,1.6rem);line-height:1.45;color:var(--ink)">The solutions aren’t mysteries. They’re measured, proven, and already running — the work is to back the ones that hold up. Four that do, with the evidence behind each —</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:clamp(16px,2.4vw,28px)">
      {solutions.map((s) => (
        <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);border:1px solid var(--rule);border-radius:10px;padding:clamp(24px,2.8vw,34px);background:var(--paper);display:flex;flex-direction:column">
          <span style="font-family:var(--mono);font-size:.72rem;color:var(--water-deep)">{s.n}</span>
          <h4 style="font-family:var(--serif);font-weight:400;font-size:clamp(1.45rem,2.3vw,1.85rem);line-height:1.05;margin:.35em 0 .45em">{s.title}</h4>
          <p style="font-size:.96rem;line-height:1.55;color:var(--ink-soft);margin:0 0 1.1em">{s.body}</p>
          <div style="margin-top:auto;padding-top:15px;border-top:1px solid var(--rule)">
            <div style="font-family:var(--mono);font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:6px">Proven by</div>
            <div style="font-size:.9rem;line-height:1.4;color:var(--ink);margin-bottom:11px">{s.proofShort}<button class="cite" data-src={s.proof} data-url={s.proofUrl} aria-label="Source" style="display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border:1px solid var(--water-deep);border-radius:50%;font-family:var(--mono);font-size:9px;color:var(--water-deep);vertical-align:super;margin-left:4px;line-height:1">i</button></div>
            <a href={s.orgUrl} target="_blank" rel="noopener" style="font-family:var(--sans);font-weight:600;font-size:.9rem;color:var(--water-deep);display:inline-flex;gap:.35em;align-items:baseline">{s.org} ↗</a>
          </div>
        </div>
      ))}
    </div>

    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1px;background:var(--rule);border:1px solid var(--rule);border-radius:10px;overflow:hidden;margin-top:clamp(30px,4.5vh,52px)">
      <div style="background:var(--paper-2);padding:clamp(24px,2.6vw,32px)">
        <div style="font-family:var(--mono);font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--water-deep);margin-bottom:15px">Get aware — the honest scoreboards</div>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:11px">
          {awareLearn.map((a) => (
            <li><a href={a.u} target="_blank" rel="noopener" style="font-size:.96rem;line-height:1.4;color:var(--ink);border-bottom:1px solid var(--rule);padding-bottom:2px">{a.t}</a></li>
          ))}
        </ul>
      </div>
      <div style="background:var(--paper-2);padding:clamp(24px,2.6vw,32px)">
        <div style="font-family:var(--mono);font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--water-deep);margin-bottom:15px">Contribute — where a dollar goes furthest</div>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:11px">
          {awareGive.map((g) => (
            <li><a href={g.u} target="_blank" rel="noopener" style="font-size:.96rem;line-height:1.4;color:var(--ink);border-bottom:1px solid var(--rule);padding-bottom:2px">{g.t}</a></li>
          ))}
        </ul>
        <p style="font-family:var(--mono);font-size:.7rem;color:var(--ink-faint);margin:16px 0 0;line-height:1.5">Verify any charity before giving — starting points, not endorsements.</p>
      </div>
    </div>

    <div data-reveal style="opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.2,.6,.2,1),transform .9s cubic-bezier(.2,.6,.2,1);text-align:center;max-width:30ch;margin:clamp(64px,9vh,110px) auto 0">
      <p style="font-family:var(--serif);font-weight:400;font-size:clamp(1.9rem,4.4vw,3.2rem);line-height:1.14;margin:0">Water on paper is a promise. <span style="font-style:italic;color:var(--water-deep)">Water that is clean and within reach of everyone — regardless of wealth, caste, creed, religion, or where they were born — is the proof.</span></p>
    </div>
  </div>
</section>
