---
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Path under public/ for the share card, e.g. "og/water.png". */
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title = 'On Paper — an essay series',
  // Starts at the substance rather than repeating the <title> wordmark, so the
  // ~160 SERP characters aren't spent on text already shown in the title line.
  description = 'Essays on the distance between what is promised on paper and what actually reaches you, with India as the centrepiece.',
  ogImage = 'og/hub.png',
  ogImageAlt = 'On Paper — an essay series. The world’s water as 100 drops: 3 fresh, 1 within reach.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
// Canonical/OG URLs. Astro.site is set in astro.config.mjs.
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;
const ogImageUrl = Astro.site ? new URL(`${base}${ogImage}`, Astro.site).href : `${base}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f8f5ee" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="On Paper" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts are self-hosted (src/styles/fonts.css, SIL OFL 1.1) — no
         third-party requests. Preload the above-the-fold faces. -->
    <link rel="preload" href={`${base}fonts/instrument-serif-400-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/instrument-serif-400-italic-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/spline-sans-400-latin.woff2`} as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
